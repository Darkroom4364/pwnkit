{
  "name": "@pwnkit/benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "bench": "tsx src/runner.ts",
    "bench:quick": "tsx src/runner.ts --depth quick",
    "bench:agentic": "tsx src/runner.ts --agentic --runtime auto",
    "bench:agentic:api": "tsx src/runner.ts --agentic --runtime api",
    "xbow": "tsx src/xbow-runner.ts",
    "xbow:dry": "tsx src/xbow-runner.ts --dry-run",
    "xbow:quick": "tsx src/xbow-runner.ts --limit 5",
    "xbow:agentic": "tsx src/xbow-runner.ts --agentic",
    "xbow:ensemble": "tsx src/xbow-runner.ts --agentic --runtime api --models anthropic/claude-sonnet-4.6,google/gemini-2.5-pro,openai/o3",
    "xbow:whitebox": "tsx src/xbow-runner.ts --agentic --white-box",
    "autopenbench": "tsx src/autopenbench-runner.ts",
    "autopenbench:dry": "tsx src/autopenbench-runner.ts --dry-run",
    "cybench": "tsx src/cybench-runner.ts",
    "cybench:dry": "tsx src/cybench-runner.ts --dry-run",
    "cybench:quick": "tsx src/cybench-runner.ts --limit 5",
    "cybench:10": "tsx src/cybench-runner.ts --limit 10",
    "hackbench": "tsx src/hackbench-runner.ts",
    "hackbench:dry": "tsx src/hackbench-runner.ts --dry-run",
    "hackbench:agentic": "tsx src/hackbench-runner.ts --agentic",
    "argus": "tsx src/argus-runner.ts",
    "argus:dry": "tsx src/argus-runner.ts --dry-run",
    "argus:quick": "tsx src/argus-runner.ts --limit 10",
    "argus:agentic": "tsx src/argus-runner.ts --agentic",
    "htb": "tsx src/htb-runner.ts",
    "htb:dry": "tsx src/htb-runner.ts --dry-run",
    "htb:quick": "tsx src/htb-runner.ts --limit 5",
    "htb:tier1": "tsx src/htb-runner.ts --tier 1",
    "picoctf": "tsx src/picoctf-runner.ts",
    "picoctf:dry": "tsx src/picoctf-runner.ts --dry-run",
    "picoctf:quick": "tsx src/picoctf-runner.ts --limit 10",
    "picoctf:web": "tsx src/picoctf-runner.ts --category web",
    "harmbench": "tsx src/harmbench-runner.ts",
    "harmbench:vulnerable": "tsx src/harmbench-runner.ts --test-target vulnerable",
    "harmbench:safe": "tsx src/harmbench-runner.ts --test-target safe",
    "harmbench:quick": "tsx src/harmbench-runner.ts --test-target vulnerable --limit 20",
    "harmbench:json": "tsx src/harmbench-runner.ts --json",
    "adversarial-tool-misuse": "tsx src/adversarial-tool-misuse-runner.ts",
    "adversarial-indirect-prompt-injection": "tsx src/adversarial-indirect-prompt-injection-runner.ts",
    "adversarial-persistence": "tsx src/adversarial-persistence-runner.ts",
    "npm-bench": "tsx src/npm-bench.ts",
    "npm-bench:json": "tsx src/npm-bench.ts --json",
    "consolidate-xbow": "tsx src/scripts/consolidate-xbow.ts",
    "compare:xbow": "tsx src/compare-xbow.ts",
    "report": "tsx src/report.ts",
    "triage-data": "tsx src/triage-data-collector.ts",
    "triage-data:results": "tsx src/triage-data-collector.ts --results results/xbow-latest.json --output results/triage-data-latest.jsonl",
    "test": "vitest run"
  },
  "dependencies": {
    "@pwnkit/core": "workspace:*",
    "@pwnkit/shared": "workspace:*",
    "@pwnkit/test-targets": "workspace:*",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
