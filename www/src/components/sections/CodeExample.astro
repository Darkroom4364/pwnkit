---
---

<section id="ci" data-section="ci" class="py-16 sm:py-24 md:py-32 border-t border-white/5">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 text-white bg-crimson/10 px-2.5 py-1 rounded font-medium text-xs mb-6 border border-crimson/20">
        <span class="w-1.5 h-1.5 rounded-full bg-crimson"></span>
        CI/CD &middot; SARIF
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: 'Outfit', sans-serif">Findings in GitHub's Security tab.</h2>
      <p class="text-ash text-sm max-w-2xl mx-auto">Drop the action into your workflow. Verified findings show up alongside CodeQL and Dependabot.</p>
    </div>

    <div class="rounded-xl overflow-hidden border border-border">
      <div class="bg-night-lighter border-b border-border px-4 py-2.5 flex items-center gap-2">
        <span class="text-xs text-ash font-mono">.github/workflows/pwnkit.yml</span>
      </div>
      <pre class="bg-night-light p-6 font-mono text-sm text-smoke overflow-x-auto leading-relaxed"><code><span class="text-ash">name:</span> <span class="text-white">Security Pentest</span>
<span class="text-ash">on:</span> <span class="text-white">[push, pull_request]</span>

<span class="text-ash">jobs:</span>
  <span class="text-white">pwnkit:</span>
    <span class="text-ash">runs-on:</span> <span class="text-smoke">ubuntu-latest</span>
    <span class="text-ash">steps:</span>
      - <span class="text-ash">uses:</span> <span class="text-smoke">actions/checkout@v4</span>
      - <span class="text-ash">name:</span> <span class="text-white">Run pwnkit</span>
        <span class="text-ash">uses:</span> <span class="text-smoke">peaktwilight/pwnkit/action@v1</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">target:</span> <span class="text-crimson">${"${{ secrets.STAGING_API_URL }}"}</span>
      - <span class="text-ash">name:</span> <span class="text-white">Upload SARIF</span>
        <span class="text-ash">uses:</span> <span class="text-smoke">github/codeql-action/upload-sarif@v3</span>
        <span class="text-ash">with:</span>
          <span class="text-ash">sarif_file:</span> <span class="text-smoke">pwnkit-report/report.sarif</span></code></pre>
    </div>
  </div>
</section>
