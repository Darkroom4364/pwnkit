---
import PwnkitHero3D from '../PwnkitHero3D';
---

<section data-section="hero" class="relative min-h-screen pt-16 sm:pt-24 pb-12 sm:pb-16 overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <!-- 3D pwnkit character -->
    <div class="animate-fade-up">
      <PwnkitHero3D client:only="react" />
    </div>

    <div class="animate-fade-up">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-6" style="font-family: 'Outfit', sans-serif">
        Let autonomous AI agents hack you<br/><span class="text-crimson">so the real ones can't.</span>
      </h1>
      <p class="text-smoke text-lg mb-10 max-w-2xl mx-auto">The leading open-source AI pentest agent.</p>
    </div>

    <!-- Hero stat -->
    <div class="mt-8 mb-10 animate-fade-up">
      <div class="text-7xl sm:text-8xl md:text-9xl font-bold tracking-tighter text-white"
           style="font-family: 'JetBrains Mono', 'Fira Code', monospace; line-height: 0.9;">
        87.5<span class="text-crimson">%</span>
      </div>
      <div class="text-xs sm:text-sm text-ash mt-3 tracking-wider uppercase">
        on XBOW &middot; 91 of 104 challenges
      </div>
    </div>

    <!-- CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-4 animate-fade-up" style="animation-delay: 0.2s">
      <div class="copy-wrap relative inline-flex items-center group">
        <code class="bg-night-lighter border border-border rounded-lg px-5 py-3 pr-11 text-sm font-mono text-white select-all cursor-pointer hover:border-crimson/40 transition-colors" data-copy="npx pwnkit-cli">npx pwnkit-cli</code>
        <button class="copy-btn absolute right-2 p-1.5 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli">
          <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
        </button>
      </div>
      <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white hover:bg-white/90 text-black font-medium rounded-lg border border-white px-5 py-3 transition-colors text-sm">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
    <p class="text-xs text-ash mb-16 animate-fade-up" style="animation-delay: 0.3s">
      Or read the <a href="https://docs.pwnkit.com" target="_blank" rel="noopener" class="text-smoke underline underline-offset-2 decoration-white/20 hover:decoration-white/50 hover:text-white transition-colors">documentation</a>
    </p>

    <!-- Demo video -->
    <div class="animate-fade-up max-w-5xl mx-auto" style="animation-delay: 0.4s">
      <div class="rounded-xl overflow-hidden border border-border hover:border-crimson/30 transition-all duration-500 shadow-[0_0_60px_-15px_rgba(220,38,38,0.15)]">
        <video src="/demo.mp4" autoplay loop muted playsinline class="w-full block" style="max-width: 100%"></video>
      </div>
      <!-- Static fallback for no-JS -->
      <noscript>
      <div class="rounded-xl overflow-hidden border border-border">
        <div class="bg-night-lighter border-b border-border px-4 py-2.5 flex items-center gap-2">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
          </div>
          <span class="text-xs text-ash font-mono ml-2">Terminal</span>
        </div>
        <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
          <div class="text-ash terminal-line">$ npx pwnkit-cli express</div>
          <div class="terminal-line">&nbsp;</div>
          <div class="text-smoke terminal-line">
            <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> pwnkit-cli v0.3.4
          </div>
          <div class="text-smoke terminal-line">
            <span class="inline-block w-2 h-2 rounded-sm bg-crimson"></span> Target: https://demo.app/api/chat
          </div>
          <div class="terminal-line">&nbsp;</div>
          <div class="text-emerald-400 terminal-line">
            &#9656; Discover &nbsp;Found 3 endpoints, system prompt extracted
          </div>
          <div class="text-amber-400 terminal-line">
            &#9656; Attack &nbsp;&nbsp;&nbsp;Ran 47 test cases across 6 categories
          </div>
          <div class="text-blue-400 terminal-line">
            &#9656; Verify &nbsp;&nbsp;&nbsp;Confirmed 4 of 7 findings (3 false positives eliminated)
          </div>
          <div class="text-purple-400 terminal-line">
            &#9656; Report &nbsp;&nbsp;&nbsp;Written to ./pwnkit-report/
          </div>
          <div class="terminal-line">&nbsp;</div>
          <div class="terminal-line">
            <span class="text-crimson font-bold">4 verified vulnerabilities found.</span>
          </div>
        </div>
      </div>
      </noscript>
    </div>
  </div>
</section>
