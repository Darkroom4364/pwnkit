---
---

<section class="border-t border-white/5 py-16 sm:py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-white mb-4" style="font-family: 'Outfit', sans-serif">
        Detect. <span class="text-ash">Prevent.</span> <span class="text-ash">Respond.</span>
      </h2>
      <p class="text-sm text-ash max-w-2xl mx-auto">Three tools, one philosophy: open source, agentic, no vendor lock-in.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
      <!-- Detect -->
      <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="group bg-night-lighter border border-crimson/40 rounded-xl p-8 hover:border-crimson/70 transition-all">
        <div class="flex items-center justify-between mb-5">
          <span class="text-[10px] uppercase tracking-[0.15em] text-crimson font-mono font-semibold">Detect</span>
          <svg class="w-4 h-4 text-ash group-hover:text-crimson transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif">pwnkit</h3>
        <p class="text-sm text-smoke leading-relaxed mb-5">Autonomous AI pentester. Attacks web apps, LLM apps, npm packages, source code &mdash; then re-exploits to verify.</p>
        <div class="flex items-center gap-2 text-[10px] text-ash font-mono">
          <span class="w-1 h-1 rounded-full bg-crimson"></span>
          <span>87.5% on XBOW</span>
        </div>
      </a>

      <!-- Prevent -->
      <a href="https://github.com/peaktwilight/foxguard" target="_blank" rel="noopener" class="group bg-night-lighter border border-border rounded-xl p-8 hover:border-white/30 transition-all">
        <div class="flex items-center justify-between mb-5">
          <span class="text-[10px] uppercase tracking-[0.15em] text-ash font-mono font-semibold">Prevent</span>
          <svg class="w-4 h-4 text-ash group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif">foxguard</h3>
        <p class="text-sm text-smoke leading-relaxed mb-5">Rust-native SAST. The cross-validator behind pwnkit's findings. Rules + neural agreement, fully deterministic.</p>
        <div class="flex items-center gap-2 text-[10px] text-ash font-mono">
          <span class="w-1 h-1 rounded-full bg-white/40"></span>
          <span>Cross-validates pwnkit</span>
        </div>
      </a>

      <!-- Respond -->
      <a href="https://github.com/opensoar-hq/opensoar-core" target="_blank" rel="noopener" class="group bg-night-lighter border border-border rounded-xl p-8 hover:border-white/30 transition-all">
        <div class="flex items-center justify-between mb-5">
          <span class="text-[10px] uppercase tracking-[0.15em] text-ash font-mono font-semibold">Respond</span>
          <svg class="w-4 h-4 text-ash group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif">opensoar</h3>
        <p class="text-sm text-smoke leading-relaxed mb-5">Python-native SOAR. Playbook-driven incident response. Closes the loop from detection to remediation.</p>
        <div class="flex items-center gap-2 text-[10px] text-ash font-mono">
          <span class="w-1 h-1 rounded-full bg-white/40"></span>
          <span>Playbook automation</span>
        </div>
      </a>
    </div>
  </div>
</section>
