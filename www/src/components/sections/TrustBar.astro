---
<section class="py-10 sm:py-14 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-center text-xs uppercase tracking-widest text-ash mb-8">
      Benchmarked against
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6 grayscale opacity-60 hover:opacity-100 transition-opacity">
      <!-- XBOW -->
      <a href="https://github.com/xbow-engineering/validation-benchmarks" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">XBOW</div>
        <div class="text-[10px] text-ash text-center mt-1">87.5%</div>
      </a>

      <!-- Cybench -->
      <a href="https://github.com/andyzorigin/cybench" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">Cybench</div>
        <div class="text-[10px] text-ash text-center mt-1">80%</div>
      </a>

      <!-- HackTheBox -->
      <a href="https://hackthebox.com" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">HTB</div>
        <div class="text-[10px] text-ash text-center mt-1">via Cybench</div>
      </a>

      <!-- picoCTF -->
      <a href="https://picoctf.org" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">picoCTF</div>
        <div class="text-[10px] text-ash text-center mt-1">via Cybench</div>
      </a>

      <!-- AutoPenBench -->
      <a href="https://github.com/lucagioacchini/auto-pen-bench" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">AutoPenBench</div>
        <div class="text-[10px] text-ash text-center mt-1">CI ready</div>
      </a>

      <!-- HarmBench -->
      <a href="https://www.harmbench.org" target="_blank" rel="noopener" class="group">
        <div class="text-xl font-bold text-white group-hover:text-crimson transition-colors" style="font-family: 'JetBrains Mono', monospace">HarmBench</div>
        <div class="text-[10px] text-ash text-center mt-1">harness ready</div>
      </a>
    </div>
  </div>
</section>
