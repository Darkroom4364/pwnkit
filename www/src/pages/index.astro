<script>
  // Animate the hero number counter once on mount
  (() => {
    const el = document.querySelector('[data-counter]') as HTMLElement | null;
    if (!el) return;
    const target = parseFloat(el.dataset.counter || '0');
    const suffix = el.dataset.suffix || '';
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      // ease-out cubic
      const eased = 1 - Math.pow(1 - t, 3);
      const value = (target * eased).toFixed(1);
      el.textContent = `${value}${suffix.startsWith('%') ? suffix : '% on XBOW (90/104)'}`;
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = `${target}% on XBOW (90/104)`;
    };
    requestAnimationFrame(tick);
  })();

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      checkIcon.style.color = '#22c55e';
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
        checkIcon.style.color = '';
      }, 1500);
    });
  });
</script>
