---
import Layout from '../layouts/Layout.astro';
import DockNav from '../components/DockNav';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import WhatYouCanScan from '../components/sections/WhatYouCanScan.astro';
import BenchmarkTable from '../components/sections/BenchmarkTable.astro';
import WhyPwnkit from '../components/sections/WhyPwnkit.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Credibility from '../components/sections/Credibility.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Trinity from '../components/sections/Trinity.astro';
---

<Layout
  title="pwnkit — The leading open-source AI pentest agent"
  description="Autonomous AI agents that pentest web apps, AI/LLM apps, npm packages, and source code. 86.5% on XBOW. Open source. Apache 2.0."
>
  <main>
    <Hero />
    <TrustBar />
    <WhatYouCanScan />
    <BenchmarkTable />
    <WhyPwnkit />
    <HowItWorks />
    <Credibility />
    <Trinity />
    <FinalCTA />
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-10">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ash">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-sm bg-crimson inline-block"></span>
        <span>pwnkit</span>
        <span>&middot;</span>
        <span>Apache 2.0</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
        <a href="https://github.com/peaktwilight/pwnkit/issues" target="_blank" rel="noopener" class="hover:text-white transition-colors">Issues</a>
        <a href="https://www.npmjs.com/package/pwnkit-cli" target="_blank" rel="noopener" class="hover:text-white transition-colors">npm</a>
      </div>
    </div>
  </footer>

  <DockNav client:load />

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const text = (btn as HTMLElement).dataset.copy || '';
        await navigator.clipboard.writeText(text);
        const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        checkIcon.style.color = '#DC2626';
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
          checkIcon.style.color = '';
        }, 1500);
      });
    });
  </script>
</Layout>
