---
import Layout from '../layouts/Layout.astro';
import TerminalHero from '../components/TerminalHero';
import PipelineViz from '../components/PipelineViz';
import AnimatedSection from '../components/AnimatedSection';
---

<Layout title="Nightfang - Open-source pentesting toolkit for AI, code, and supply chain">

  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-night/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-mono font-bold text-lg tracking-tight">
        <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> nightfang
      </a>
      <div class="flex items-center gap-6 text-sm text-smoke">
        <a href="#commands" class="hover:text-white transition-colors hidden sm:block">Commands</a>
        <a href="#pipeline" class="hover:text-white transition-colors hidden sm:block">Pipeline</a>
        <a href="#comparison" class="hover:text-white transition-colors hidden sm:block">Compare</a>
        <a href="/blog/why-i-built-nightfang" class="hover:text-white transition-colors hidden sm:block">Blog</a>
        <a href="https://github.com/peaktwilight/nightfang" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md px-3 py-1.5 text-white transition-colors text-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main>

    <!-- Hero -->
    <section class="relative min-h-screen flex items-center justify-center pt-14 overflow-hidden">
      <div class="absolute inset-0 grid-bg-crimson"></div>
      <div class="hero-glow animate-spotlight"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,#0a0a0a_80%)]"></div>

      <div class="relative max-w-4xl mx-auto px-6 text-center z-10">
        <div class="animate-fade-up">
          <p class="inline-flex items-center gap-2 text-sm font-medium text-crimson mb-8 border border-crimson/20 rounded-full px-4 py-1.5 bg-crimson/5">
            <span class="w-1.5 h-1.5 rounded-full bg-crimson animate-pulse"></span>
            Open source &middot; MIT licensed
          </p>
          <h1 class="font-mono text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-6">
            Pentest your AI, code,<br class="hidden sm:block"/>and supply chain
          </h1>
          <h2 class="text-crimson font-mono text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 animate-fade-up" style="animation-delay: 0.15s">
            with autonomous agents.
          </h2>
          <p class="text-lg sm:text-xl text-smoke max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-up" style="animation-delay: 0.25s">
            Five commands. Four AI agents. Scan LLM endpoints, audit npm packages, review source code, test MCP servers &mdash; then prove every finding is exploitable.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up" style="animation-delay: 0.35s">
          <div class="group relative">
            <code class="block bg-night-lighter border border-white/10 rounded-lg px-6 py-3 font-mono text-sm sm:text-base text-white select-all cursor-pointer hover:border-crimson/30 transition-all duration-300 hover:shadow-[0_0_30px_rgba(220,38,38,0.1)]">
              npx nightfang scan --target https://your-app.com/api/chat
            </code>
          </div>
          <a href="https://github.com/peaktwilight/nightfang" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-crimson hover:bg-crimson-light text-white font-medium rounded-lg px-6 py-3 transition-all duration-300 text-sm sm:text-base hover:shadow-[0_0_30px_rgba(220,38,38,0.2)]">
            Get started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="animate-fade-up max-w-2xl mx-auto" style="animation-delay: 0.5s">
          <TerminalHero client:visible />
          <noscript>
          <div class="glow-crimson rounded-xl overflow-hidden border border-white/10">
            <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
              </div>
              <span class="text-xs text-ash font-mono ml-2">Terminal</span>
            </div>
            <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
              <div class="text-ash">$ npx nightfang scan --target https://demo.app/api/chat</div>
              <div>&nbsp;</div>
              <div class="text-smoke">nightfang v0.1.0</div>
              <div class="text-emerald-400">&#9656; Discover  Found 3 endpoints, system prompt extracted</div>
              <div class="text-amber-400">&#9656; Attack   Ran 47 test cases across 6 categories</div>
              <div class="text-blue-400">&#9656; Verify   Confirmed 4 of 7 findings</div>
              <div class="text-purple-400">&#9656; Report   Written to ./nightfang-report/</div>
              <div>&nbsp;</div>
              <div class="text-crimson font-bold">4 verified vulnerabilities found.</div>
            </div>
          </div>
          </noscript>
        </div>
      </div>
    </section>

    <!-- Attack Surfaces -->
    <section class="py-28 relative">
      <hr class="section-divider" />
      <div class="max-w-6xl mx-auto px-6 pt-28">
        <AnimatedSection client:visible>
          <div class="text-center mb-16">
            <h2 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight mb-4">One toolkit. Five attack surfaces.</h2>
            <p class="text-smoke text-lg max-w-xl mx-auto">From LLM endpoints to npm packages to git repos &mdash; nightfang finds what scanners miss.</p>
          </div>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.15}>
          <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-crimson/20 transition-all duration-300 text-center group">
              <div class="w-10 h-10 mx-auto mb-4 text-crimson opacity-80 group-hover:opacity-100 transition-opacity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <h3 class="font-mono font-semibold text-sm mb-1.5">LLM Endpoints</h3>
              <p class="text-xs text-ash leading-relaxed">ChatGPT, Claude, Llama APIs, custom chatbots</p>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-crimson/20 transition-all duration-300 text-center group">
              <div class="w-10 h-10 mx-auto mb-4 text-crimson opacity-80 group-hover:opacity-100 transition-opacity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6m0 8v6M4.93 4.93l4.24 4.24m5.66 5.66l4.24 4.24M2 12h6m8 0h6M4.93 19.07l4.24-4.24m5.66-5.66l4.24-4.24"/></svg></div>
              <h3 class="font-mono font-semibold text-sm mb-1.5">MCP Servers</h3>
              <p class="text-xs text-ash leading-relaxed">Tool schemas, validation, auth, poisoning</p>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-crimson/20 transition-all duration-300 text-center group">
              <div class="w-10 h-10 mx-auto mb-4 text-crimson opacity-80 group-hover:opacity-100 transition-opacity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
              <h3 class="font-mono font-semibold text-sm mb-1.5">npm Packages</h3>
              <p class="text-xs text-ash leading-relaxed">Supply chain, malicious code, dependency risk</p>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-crimson/20 transition-all duration-300 text-center group">
              <div class="w-10 h-10 mx-auto mb-4 text-crimson opacity-80 group-hover:opacity-100 transition-opacity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div>
              <h3 class="font-mono font-semibold text-sm mb-1.5">Source Code</h3>
              <p class="text-xs text-ash leading-relaxed">Local repos, GitHub URLs, deep AI audit</p>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-crimson/20 transition-all duration-300 text-center group">
              <div class="w-10 h-10 mx-auto mb-4 text-crimson opacity-80 group-hover:opacity-100 transition-opacity"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg></div>
              <h3 class="font-mono font-semibold text-sm mb-1.5">Web Apps</h3>
              <p class="text-xs text-ash leading-relaxed">AI copilots, RAG pipelines, agent APIs</p>
            </div>
          </div>
        </AnimatedSection>
      </div>
    </section>

    <!-- Commands -->
    <section id="commands" class="py-28 relative">
      <hr class="section-divider" />
      <div class="max-w-6xl mx-auto px-6 pt-28">
        <AnimatedSection client:visible>
          <div class="text-center mb-16">
            <h2 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight mb-4">Five commands. Full coverage.</h2>
            <p class="text-smoke text-lg max-w-xl mx-auto">Each command is purpose-built for a different attack surface. Zero config, instant results.</p>
          </div>
        </AnimatedSection>

        <div class="space-y-4">
          <AnimatedSection client:visible delay={0.05}><div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl overflow-hidden hover:border-crimson/20 transition-all duration-300"><div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6"><div class="flex-1 min-w-0"><div class="flex items-center gap-3 mb-2"><span class="text-xs font-mono text-crimson bg-crimson/10 px-2.5 py-1 rounded-md uppercase tracking-wider">scan</span><h3 class="font-semibold text-lg">Probe LLM endpoints &amp; MCP servers</h3></div><p class="text-smoke text-sm leading-relaxed mb-3">Discovers vulnerabilities in AI endpoints with 47+ test cases across prompt injection, jailbreaks, tool poisoning, data exfiltration, and more.</p><div class="flex flex-wrap gap-2"><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--mode probe|deep|mcp</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--depth quick|default|deep</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--agentic</span></div></div><div class="lg:w-[340px] shrink-0"><code class="block bg-night border border-white/[0.06] rounded-lg px-4 py-3 font-mono text-xs text-smoke select-all">npx nightfang scan --target &lt;url&gt;</code></div></div></div></AnimatedSection>

          <AnimatedSection client:visible delay={0.1}><div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl overflow-hidden hover:border-amber-400/20 transition-all duration-300"><div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6"><div class="flex-1 min-w-0"><div class="flex items-center gap-3 mb-2"><span class="text-xs font-mono text-amber-400 bg-amber-400/10 px-2.5 py-1 rounded-md uppercase tracking-wider">audit</span><h3 class="font-semibold text-lg">Audit npm packages for malicious code</h3></div><p class="text-smoke text-sm leading-relaxed mb-3">Installs a package in a sandbox, runs semgrep static analysis plus AI-powered code review. Catches supply chain attacks and backdoors.</p><div class="flex flex-wrap gap-2"><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--version &lt;ver&gt;</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--depth quick|default|deep</span></div></div><div class="lg:w-[340px] shrink-0"><code class="block bg-night border border-white/[0.06] rounded-lg px-4 py-3 font-mono text-xs text-smoke select-all">npx nightfang audit &lt;package&gt;</code></div></div></div></AnimatedSection>

          <AnimatedSection client:visible delay={0.15}><div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl overflow-hidden hover:border-blue-400/20 transition-all duration-300"><div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6"><div class="flex-1 min-w-0"><div class="flex items-center gap-3 mb-2"><span class="text-xs font-mono text-blue-400 bg-blue-400/10 px-2.5 py-1 rounded-md uppercase tracking-wider">review</span><h3 class="font-semibold text-lg">Deep security audit of source code</h3></div><p class="text-smoke text-sm leading-relaxed mb-3">Security-focused code review of local repos or GitHub URLs. Multiple AI runtimes analyze your codebase and output SARIF, Markdown, and JSON reports.</p><div class="flex flex-wrap gap-2"><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--runtime api|claude|codex|gemini|auto</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--depth quick|default|deep</span></div></div><div class="lg:w-[340px] shrink-0"><code class="block bg-night border border-white/[0.06] rounded-lg px-4 py-3 font-mono text-xs text-smoke select-all">npx nightfang review &lt;repo&gt;</code></div></div></div></AnimatedSection>

          <AnimatedSection client:visible delay={0.2}><div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl overflow-hidden hover:border-purple-400/20 transition-all duration-300"><div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6"><div class="flex-1 min-w-0"><div class="flex items-center gap-3 mb-2"><span class="text-xs font-mono text-purple-400 bg-purple-400/10 px-2.5 py-1 rounded-md uppercase tracking-wider">findings</span><h3 class="font-semibold text-lg">Query and inspect verified findings</h3></div><p class="text-smoke text-sm leading-relaxed mb-3">Filter findings by severity, category, and status. Inspect individual findings with full evidence chains and proof artifacts.</p><div class="flex flex-wrap gap-2"><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">list --severity critical</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">show NF-001</span></div></div><div class="lg:w-[340px] shrink-0"><code class="block bg-night border border-white/[0.06] rounded-lg px-4 py-3 font-mono text-xs text-smoke select-all">npx nightfang findings list</code></div></div></div></AnimatedSection>

          <AnimatedSection client:visible delay={0.25}><div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl overflow-hidden hover:border-emerald-400/20 transition-all duration-300"><div class="p-6 flex flex-col lg:flex-row lg:items-center gap-6"><div class="flex-1 min-w-0"><div class="flex items-center gap-3 mb-2"><span class="text-xs font-mono text-emerald-400 bg-emerald-400/10 px-2.5 py-1 rounded-md uppercase tracking-wider">history</span><h3 class="font-semibold text-lg">Browse past scan results</h3></div><p class="text-smoke text-sm leading-relaxed mb-3">Query the local SQLite database for previous scans. Track status, depth, findings count, and duration over time.</p><div class="flex flex-wrap gap-2"><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--limit 20</span><span class="text-xs font-mono text-ash bg-white/[0.03] px-2 py-0.5 rounded">--db-path ./custom.db</span></div></div><div class="lg:w-[340px] shrink-0"><code class="block bg-night border border-white/[0.06] rounded-lg px-4 py-3 font-mono text-xs text-smoke select-all">npx nightfang history</code></div></div></div></AnimatedSection>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="py-28 relative">
      <hr class="section-divider" />
      <div class="max-w-6xl mx-auto px-6 pt-28">
        <AnimatedSection client:visible>
          <div class="grid md:grid-cols-3 gap-10">
            <div class="space-y-4">
              <div class="w-12 h-12 rounded-xl bg-crimson/10 flex items-center justify-center text-crimson"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg></div>
              <h3 class="font-mono text-lg font-semibold">One command, zero config</h3>
              <p class="text-smoke text-sm leading-relaxed">No YAML files. No Python environments. Just <code class="text-white bg-white/5 px-1.5 py-0.5 rounded text-xs font-mono">npx nightfang scan</code> and you are running.</p>
            </div>
            <div class="space-y-4">
              <div class="w-12 h-12 rounded-xl bg-crimson/10 flex items-center justify-center text-crimson"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
              <h3 class="font-mono text-lg font-semibold">Zero false positives</h3>
              <p class="text-smoke text-sm leading-relaxed">Every finding is re-exploited with proof before it hits the report. No more triaging 200 "possible prompt injections."</p>
            </div>
            <div class="space-y-4">
              <div class="w-12 h-12 rounded-xl bg-crimson/10 flex items-center justify-center text-crimson"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
              <h3 class="font-mono text-lg font-semibold">$0.05 per CI scan</h3>
              <p class="text-smoke text-sm leading-relaxed">Quick scans in under a minute. Deep audits for $1. Cheaper than one hour of manual pentesting.</p>
            </div>
          </div>
        </AnimatedSection>
      </div>
    </section>

    <!-- Pipeline -->
    <section id="pipeline" class="py-28 relative">
      <hr class="section-divider" />
      <div class="max-w-6xl mx-auto px-6 pt-28">
        <AnimatedSection client:visible>
          <div class="text-center mb-16">
            <h2 class="font-mono text-3xl sm:text-4xl font-bold tracking-tight mb-4">Four agents. One pipeline.</h2>
            <p class="text-smoke text-lg max-w-xl mx-auto">Each agent is specialized for a phase of the security audit. They work in sequence, building on each other's output.</p>
          </div>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.1}>
          <div class="mb-14">
            <PipelineViz client:visible />
          </div>
        </AnimatedSection>

        <AnimatedSection client:visible delay={0.2}>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-emerald-500/20 transition-all duration-300 h-full">
              <div class="text-xs font-mono text-emerald-400 mb-3 uppercase tracking-wider">01 &middot; Discover</div>
              <h3 class="font-semibold text-lg mb-2">Recon</h3>
              <p class="text-smoke text-sm leading-relaxed">Maps endpoints, model cards, system prompts, MCP tool schemas, and auth flows.</p>
              <div class="mt-4 pt-4 border-t border-white/[0.04] text-xs text-ash font-mono space-y-1.5"><div>&#8226; API surface mapping</div><div>&#8226; System prompt extraction</div><div>&#8226; MCP tool enumeration</div></div>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-amber-500/20 transition-all duration-300 h-full">
              <div class="text-xs font-mono text-amber-400 mb-3 uppercase tracking-wider">02 &middot; Attack</div>
              <h3 class="font-semibold text-lg mb-2">Offense</h3>
              <p class="text-smoke text-sm leading-relaxed">Runs prompt injection, jailbreaks, tool poisoning, data exfiltration, and more.</p>
              <div class="mt-4 pt-4 border-t border-white/[0.04] text-xs text-ash font-mono space-y-1.5"><div>&#8226; 47+ test cases</div><div>&#8226; OWASP LLM Top 10</div><div>&#8226; 6 attack categories</div></div>
            </div>
            <div class="bg-night-lighter/60 border border-white/[0.06] rounded-xl p-6 hover:border-blue-500/20 transition-all duration-300 h-full">
              <div class="text-xs font-mono text-blue-400 mb-3 uppercase tracking-wider">03 &middot; Verify</div>
              <h3 class="font-semibold text-lg mb-2">Validation</h3>
              <p class="text-smoke text-sm leading-relaxed">Re-exploits each finding to eliminate false positives. Captures proof artifacts.</p>
