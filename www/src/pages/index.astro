---
import Layout from '../layouts/Layout.astro';
import PipelineViz from '../components/PipelineViz';
import DockNav from '../components/DockNav';
import DataGridBackground from '../components/DataGridBackground';
import PwnkitHero3D from '../components/PwnkitHero3D';
---

<Layout
  title="pwnkit - The leading open-source AI pentest agent (86.5% on XBOW)"
  description="The only maintained open-source AI pentest agent above 85% on the standard XBOW benchmark. 86.5% (90/104) — single command, single configuration, no white-box tricks. Apache 2.0."
>


  <main>

    <!-- Hero -->
    <section data-section="hero" class="relative min-h-screen pt-16 sm:pt-24 pb-12 sm:pb-16 overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <!-- 3D pwnkit character -->
        <div class="animate-fade-up">
          <PwnkitHero3D client:only="react" />
        </div>

        <div class="animate-fade-up">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] mb-6" style="font-family: 'Outfit', sans-serif">
            Let autonomous AI agents hack you<br/><span class="text-crimson">so the real ones can't.</span>
          </h1>
          <p class="text-smoke text-lg mb-4 max-w-2xl mx-auto">The only maintained open-source AI pentest agent above 85% on the standard XBOW benchmark.<br/><span class="text-white">86.5% (90/104) &mdash; one command, one configuration, no white-box tricks.</span></p>
          <div class="flex flex-wrap items-center justify-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-crimson/40 bg-crimson/10 text-xs font-mono text-white">
              <span class="w-1.5 h-1.5 rounded-full bg-crimson animate-pulse"></span>
              <span data-counter="86.5" data-suffix="% on XBOW (90/104)">86.5% on XBOW (90/104)</span>
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-xs font-mono text-smoke">
              188 tests passing
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-xs font-mono text-smoke">
              11-layer FP filter
            </span>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-4 animate-fade-up" style="animation-delay: 0.2s">
          <div class="copy-wrap relative inline-flex items-center group">
            <code class="bg-night-lighter border border-white/10 rounded-lg px-5 py-3 pr-11 text-sm font-mono text-white select-all cursor-pointer hover:border-crimson/30 transition-colors" data-copy="npx pwnkit-cli">npx pwnkit-cli</code>
            <button class="copy-btn absolute right-2 p-1.5 rounded-md text-ash hover:text-white hover:bg-white/10 transition-all" aria-label="Copy command" data-copy="npx pwnkit-cli">
              <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
            </button>
          </div>
          <a href="https://github.com/peaktwilight/pwnkit" target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white hover:bg-white/90 text-black font-medium rounded-lg px-5 py-3 transition-colors text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
        <p class="text-xs text-ash mb-16 animate-fade-up" style="animation-delay: 0.3s">
          Or read the <a href="https://docs.pwnkit.com" target="_blank" rel="noopener" class="text-smoke underline underline-offset-2 decoration-white/20 hover:decoration-white/50 hover:text-white transition-colors">documentation</a>
        </p>

        <!-- Demo video -->
        <div class="animate-fade-up max-w-5xl mx-auto" style="animation-delay: 0.4s">
          <div class="rounded-xl overflow-hidden border border-white/10 hover:border-crimson/20 transition-all duration-500 shadow-[0_0_60px_-15px_rgba(220,38,38,0.15)]">
            <video src="/demo.mp4" autoplay loop muted playsinline class="w-full block" style="max-width: 100%"></video>
          </div>
          <!-- Static fallback for no-JS -->
          <noscript>
          <div class="rounded-xl overflow-hidden border border-white/10">
            <div class="bg-night-lighter border-b border-white/5 px-4 py-2.5 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
              </div>
              <span class="text-xs text-ash font-mono ml-2">Terminal</span>
            </div>
            <div class="bg-night-light p-5 font-mono text-sm text-left leading-relaxed space-y-1">
              <div class="text-ash terminal-line">$ npx pwnkit-cli express</div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-smoke terminal-line">
                <svg class="w-5 h-5 inline-block" viewBox="0 0 32 32"><rect width="32" height="32" rx="6" fill="#0a0a0a"/><path d="M8 12 L16 6 L24 12 L24 22 L20 26 L16 22 L12 26 L8 22Z" fill="none" stroke="#DC2626" stroke-width="2" stroke-linejoin="round"/><circle cx="13" cy="16" r="1.5" fill="#DC2626"/><circle cx="19" cy="16" r="1.5" fill="#DC2626"/></svg> pwnkit-cli v0.3.4
              </div>
              <div class="text-smoke terminal-line">
                <span class="inline-block w-2 h-2 rounded-sm bg-crimson"></span> Target: https://demo.app/api/chat
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="text-emerald-400 terminal-line">
                &#9656; Discover &nbsp;Found 3 endpoints, system prompt extracted
              </div>
              <div class="text-amber-400 terminal-line">
                &#9656; Attack &nbsp;&nbsp;&nbsp;Ran 47 test cases across 6 categories
              </div>
              <div class="text-blue-400 terminal-line">
                &#9656; Verify &nbsp;&nbsp;&nbsp;Confirmed 4 of 7 findings (3 false positives eliminated)
              </div>
              <div class="text-purple-400 terminal-line">
                &#9656; Report &nbsp;&nbsp;&nbsp;Written to ./pwnkit-report/
              </div>
              <div class="terminal-line">&nbsp;</div>
              <div class="terminal-line">
                <span class="text-crimson font-bold">4 verified vulnerabilities found.</span>
              </div>
              <div class="terminal-line">
                <table class="w-full text-xs sm:text-sm mt-2 border-collapse">
                  <thead>
                    <tr class="text-ash border-b border-white/10">
                      <th class="text-left py-1 pr-4">ID</th>
                      <th class="text-left py-1 pr-4">Finding</th>
                      <th class="text-left py-1 pr-4">Risk</th>
                      <th class="text-left py-1">Conf</th>
                    </tr>
                  </thead>
                  <tbody class="text-smoke">
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-001</td>
                      <td class="py-1 pr-4">Direct prompt injection</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">99%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-002</td>
                      <td class="py-1 pr-4">System prompt extraction</td>
                      <td class="py-1 pr-4 text-amber-400 font-medium">MED</td>
                      <td class="py-1">95%</td>
                    </tr>
                    <tr class="border-b border-white/5">
                      <td class="py-1 pr-4 text-white">NF-003</td>
                      <td class="py-1 pr-4">SSRF via tool callback</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">97%</td>
                    </tr>
                    <tr>
                      <td class="py-1 pr-4 text-white">NF-004</td>
                      <td class="py-1 pr-4">PII leak in chat context</td>
                      <td class="py-1 pr-4 text-crimson font-medium">HIGH</td>
                      <td class="py-1">92%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          </noscript>
        </div>
      </div>
    </section>

    <!-- What you can scan -->
    <section class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 text-center" style="font-family: 'Outfit', sans-serif">Shell-first. Minimal tools. Real exploits.</h2>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">Web Apps</h3>
            <p class="text-xs text-ash">SQLi, IDOR, SSTI, XSS, auth bypass, SSRF — 35+ XBOW flags</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">AI/LLM Apps</h3>
            <p class="text-xs text-ash">Prompt injection, jailbreaks, PII leakage, MCP tool abuse</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">npm Packages</h3>
            <p class="text-xs text-ash">Supply chain attacks, malware, CVEs, typosquatting</p>
          </div>
          <div class="bg-night-lighter border border-white/5 rounded-xl p-5 hover:border-crimson/20 transition-colors text-center">
            <div class="w-8 h-8 mx-auto mb-3 text-crimson">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="font-semibold text-sm mb-1">Source Code</h3>
            <p class="text-xs text-ash">White-box mode reads code before attacking</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benchmark -->
    <section id="benchmark" data-section="benchmark" class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-3 text-center" style="font-family: 'Outfit', sans-serif">
          <span class="text-crimson">86.5%</span> on standard XBOW. One config. Still shipping.
        </h2>
        <p class="text-center text-ash text-sm mb-10 max-w-2xl mx-auto">
          90 of 104 challenges on the unmodified XBOW validation benchmark. Single model, single command, single configuration.
          The only maintained open-source agent above 85% on the standard benchmark.
        </p>

        <!-- Comparison table -->
        <div class="bg-night-lighter border border-white/5 rounded-xl p-4 sm:p-6 overflow-x-auto mb-6">
          <p class="text-[10px] text-ash mb-2 sm:hidden">Scroll to compare &rarr;</p>
          <table class="w-full text-sm min-w-[760px]">
            <thead>
              <tr class="border-b border-white/10 text-ash">
                <th class="text-left py-3 pr-4 font-medium">System</th>
                <th class="text-right py-3 px-3 font-medium">XBOW score</th>
                <th class="text-center py-3 px-3 font-medium">Maintained?</th>
                <th class="text-center py-3 px-3 font-medium">Comparable?</th>
                <th class="text-left py-3 pl-3 font-medium">Notes</th>
              </tr>
            </thead>
            <tbody class="text-smoke">
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">BoxPwnr (best-of-N)</td>
                <td class="py-2.5 px-3 text-right font-mono">97.1%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-crimson">No</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Best-of-N across 10+ model+solver configs</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">Shannon</td>
                <td class="py-2.5 px-3 text-right font-mono">96.15%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-crimson">No</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Modified hint-free fork + white-box source access</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">KinoSec</td>
                <td class="py-2.5 px-3 text-right font-mono">92.3%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-crimson">No</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Proprietary, closed source</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">XBOW (own agent)</td>
                <td class="py-2.5 px-3 text-right font-mono">85%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-crimson">No</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Built by XBOW for their own benchmark</td>
              </tr>
              <tr class="border-b-2 border-crimson/60 bg-crimson/5">
                <td class="py-3 pr-4 text-white font-semibold">pwnkit</td>
                <td class="py-3 px-3 text-right font-mono text-crimson font-bold">86.5%</td>
                <td class="py-3 px-3 text-center text-xs text-emerald-400 font-semibold">Yes</td>
                <td class="py-3 px-3 text-center text-xs text-emerald-400 font-semibold">Yes</td>
                <td class="py-3 pl-3 text-xs text-white/80">Single model, single command, standard benchmark &middot; <span class="text-emerald-400">open source</span></td>
              </tr>
              <tr class="border-b border-white/5 opacity-60">
                <td class="py-2.5 pr-4 line-through">Cyber-AutoAgent</td>
                <td class="py-2.5 px-3 text-right font-mono line-through">85%</td>
                <td class="py-2.5 px-3 text-center text-xs text-crimson font-semibold">Archived Nov 2025</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Repo archived 2025-11-29 &mdash; project is dead</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">BoxPwnr (single config)</td>
                <td class="py-2.5 px-3 text-right font-mono">~80-82%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Apples-to-apples single-config baseline</td>
              </tr>
              <tr class="border-b border-white/5">
                <td class="py-2.5 pr-4">deadend-cli</td>
                <td class="py-2.5 px-3 text-right font-mono">~80%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Open source agent</td>
              </tr>
              <tr>
                <td class="py-2.5 pr-4">MAPTA</td>
                <td class="py-2.5 px-3 text-right font-mono">76.9%</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 px-3 text-center text-xs text-emerald-400">Yes</td>
                <td class="py-2.5 pl-3 text-xs text-ash">Academic agent (arXiv:2508.20816)</td>
              </tr>
            </tbody>
          </table>
          <p class="text-[11px] text-ash mt-4 leading-relaxed">
            <span class="text-white">Comparable</span> = standard 104-challenge XBOW, single reproducible configuration, no white-box source access.
            Higher scores above pwnkit either run on a modified fork, aggregate across many configurations, or are closed source.
          </p>
        </div>

        <p class="text-center text-xs text-ash">
          Run it yourself: <code class="text-smoke">pnpm bench --agentic</code> &middot;
          <a href="https://docs.pwnkit.com/benchmark/" target="_blank" rel="noopener" class="text-smoke underline underline-offset-2 decoration-white/20 hover:text-white transition-colors">Full benchmark writeup</a>
          &middot;
          <a href="https://github.com/peaktwilight/pwnkit/tree/main/packages/benchmark" target="_blank" rel="noopener" class="text-smoke underline underline-offset-2 decoration-white/20 hover:text-white transition-colors">Source</a>
        </p>

        <!-- Why pwnkit leads -->
        <div class="mt-16">
          <h3 class="text-xl sm:text-2xl font-bold tracking-tight mb-3 text-center" style="font-family: 'Outfit', sans-serif">Why pwnkit leads</h3>
          <p class="text-center text-ash text-sm mb-8 max-w-2xl mx-auto">
            Three things every higher-scoring system gives up &mdash; and we don't.
          </p>
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-crimson/30 transition-colors">
              <div class="w-9 h-9 mb-4 text-crimson">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
              </div>
              <h4 class="font-semibold text-sm text-white mb-2" style="font-family: 'Outfit', sans-serif">Standard benchmark</h4>
              <p class="text-xs text-smoke leading-relaxed">We test on the unmodified XBOW validation benchmark. No hint-free forks. No source-aware advantages. The same 104 challenges everyone else should be running.</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-crimson/30 transition-colors">
              <div class="w-9 h-9 mb-4 text-crimson">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
              </div>
              <h4 class="font-semibold text-sm text-white mb-2" style="font-family: 'Outfit', sans-serif">Single configuration</h4>
              <p class="text-xs text-smoke leading-relaxed">One model. One prompt set. One command. Reproducible end-to-end. Not best-of-N across ten solver+model combinations &mdash; the score you see is the score you get.</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-crimson/30 transition-colors">
              <div class="w-9 h-9 mb-4 text-crimson">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h4 class="font-semibold text-sm text-white mb-2" style="font-family: 'Outfit', sans-serif">Still maintained</h4>
              <p class="text-xs text-smoke leading-relaxed">Cyber-AutoAgent was the only other open-source tool above 85% on standard XBOW. Its repo got archived November 2025. We ship daily.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pipeline diagram -->
    <section class="py-16 sm:py-24 border-t border-white/5">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-3 text-center" style="font-family: 'Outfit', sans-serif">Target &rarr; Scan &rarr; Triage &rarr; Verify &rarr; Outputs</h2>
        <p class="text-center text-ash text-sm mb-10 max-w-2xl mx-auto">
          The same plan-discover-attack-verify-report loop a real pentester runs &mdash; with an 11-layer FP filter between raw findings and the report.
        </p>

        <div class="bg-night-lighter border border-white/5 rounded-xl p-6 sm:p-8 overflow-x-auto">
